# Set a stable Dagster home so every run reuses the same storage bucket
# instead of creating a new .tmp_dagster_home_<random>/ directory each time.
export DAGSTER_HOME="$(pwd)/.dagster"

# Expose the uv-managed venv on PATH so project CLIs (dg, dagster, ruff, ty)
# resolve as bare commands. uv sync keeps .venv/bin current.
export PATH="$(pwd)/.venv/bin:$PATH"
