# Firecrawl — opportunity.org.nz
# Run `just` to list all recipes.
#
# direnv loads FIRECRAWL_API_KEY and adds node_modules/.bin to PATH automatically.
# The key is also read directly from .firecrawl-api-key as a fallback.

export FIRECRAWL_API_KEY := `cat .firecrawl-api-key`
fc := "./node_modules/.bin/firecrawl"

# List all recipes
default:
    @just --list

# ── Account ───────────────────────────────────────────────────────────────────

# Show API status, concurrency, and remaining credits
status:
    {{fc}} --status

# Show detailed credit usage for this billing cycle
credits:
    {{fc}} credit-usage

# Run environment diagnostics (auth, config, connectivity)
doctor:
    {{fc}} doctor

# ── Discovery ─────────────────────────────────────────────────────────────────

# Map all URLs on the live site
map:
    {{fc}} map https://www.opportunity.org.nz/

# Map URLs matching a search term  (e.g. just map-filter policy)
map-filter term:
    {{fc}} map https://www.opportunity.org.nz/ --search "{{term}}"

# Scrape a single page and print markdown  (e.g. just scrape https://www.opportunity.org.nz/policies/)
scrape url:
    {{fc}} scrape "{{url}}"

# Web search  (e.g. just search "Opportunity Party housing policy")
search query:
    {{fc}} search "{{query}}"

# ── Pipeline ──────────────────────────────────────────────────────────────────

# Download entire site as local markdown files into .firecrawl/
download:
    bash scripts/download.sh

# Download only a site section  (e.g. just section /policies)
section path:
    SECTION="{{path}}" bash scripts/download.sh

# Build output/llms.txt + output/llms-full.txt from a previous download
generate-llms:
    bash scripts/generate-llms.sh

# Full pipeline: download the live site then regenerate llms files
all: download generate-llms

# ── Comparison ────────────────────────────────────────────────────────────────

# Diff a downloaded page against the Dagster clean-layer equivalent
# e.g. just diff policies/index.md
diff path:
    @echo "─── Firecrawl (.firecrawl/opportunity.org.nz/{{path}}) ───"
    @cat ".firecrawl/opportunity.org.nz/{{path}}" 2>/dev/null || echo "(not downloaded)"
    @echo ""
    @echo "─── Dagster clean (../../data/clean/{{path}}) ───"
    @cat "../../data/clean/{{path}}" 2>/dev/null || echo "(not in clean layer)"
