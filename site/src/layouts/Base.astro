---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Opportunity Party</title>
    <style is:global>
      :root {
        --color-bg: #fefefe;
        --color-text: #1a1a1a;
        --color-accent: #0057b8;
        --color-muted: #555;
        --max-width: 48rem;
      }
      * { box-sizing: border-box; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        color: var(--color-text);
        background: var(--color-bg);
        margin: 0;
        line-height: 1.65;
      }
      a { color: var(--color-accent); }
      a:hover { text-decoration: underline; }
      nav {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        gap: 1.5rem;
        align-items: center;
        border-bottom: 1px solid #eee;
      }
      nav a {
        text-decoration: none;
        font-weight: 500;
        color: var(--color-accent);
      }
      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      h1, h2, h3, h4, h5, h6 {
        margin-top: 1.5em;
        margin-bottom: 0.5em;
        line-height: 1.3;
      }
      h1 { font-size: 2rem; }
      h2 { font-size: 1.5rem; }
      ul { padding-left: 1.5rem; }
      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
      }
      .card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 1.25rem;
        text-decoration: none;
        color: inherit;
      }
      .card:hover {
        border-color: var(--color-accent);
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      }
      .card h3 { margin-top: 0; }
      .meta { color: var(--color-muted); font-size: 0.9rem; }
      footer {
        max-width: var(--max-width);
        margin: 2rem auto 0;
        padding: 1rem 1.5rem;
        border-top: 1px solid #eee;
        font-size: 0.85rem;
        color: var(--color-muted);
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/"><strong>Opportunity Party</strong></a>
      <a href="/policies">Policies</a>
      <a href="/blog">Blog</a>
      <a href="/events">Events</a>
      <a href="/team">Team</a>
      <a href="/about">About</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>Content sourced from <a href="https://www.opportunity.org.nz">opportunity.org.nz</a>. This site is an LLM-accessible mirror and is not affiliated with the Opportunity Party.</p>
    </footer>
  </body>
</html>