---
import BaseLayout from "../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const aboutPages = await getCollection("party-info");
const aboutPage = aboutPages.find((p) => p.data.slug === "about");
const meetQPage = aboutPages.find((p) => p.data.slug === "meet-q");
const partyInfoPage = aboutPages.find((p) => p.data.slug === "party-information");

const { Content: AboutContent } = aboutPage ? await render(aboutPage) : { Content: null };
const { Content: MeetQContent } = meetQPage ? await render(meetQPage) : { Content: null };
---

<BaseLayout title="About">
  <h1>About the Opportunity Party</h1>

  {AboutContent && (
    <section>
      <AboutContent />
    </section>
  )}

  {meetQPage && (
    <section>
      <h2>Meet Q</h2>
      {MeetQContent && <MeetQContent />}
    </section>
  )}

  {partyInfoPage && (
    <section>
      <h2>Party Information</h2>
      <p>
        <a href={partyInfoPage.data.url}>View on opportunity.org.nz</a>
      </p>
    </section>
  )}
</BaseLayout>