# Environment variable template for the Opportunity Party site.
#
# Copy this file to .env.local and fill in the values for your environment.
# .env.local is gitignored — never commit real values.
#
#   cp .env.example .env.local
#
# ---------------------------------------------------------------------------
# Sitemap URL resolution
# ---------------------------------------------------------------------------
#
# Base URL used by `pnpm generate:sitemap` (scripts/generate-sitemap.mjs)
# to rewrite relative links in dist/docs_site_map.md into absolute URLs.
#
# The script fails fast with a clear error if this variable is not set.
#
# Local dev  →  use the Astro dev server address (default port 4321)
# Production →  set this in your Cloudflare Pages environment variables
#               (Settings → Environment variables → SITE_URL)
#
SITE_URL=http://localhost:4321
